<?xml version="1.0" encoding="utf-8"?><Regulation lims:pit-date="2026-04-17" lims:lastAmendedDate="2026-04-17" lims:current-date="2026-04-28" lims:inforce-start-date="2026-04-17" lims:enacted-date="2026-04-17" lims:fid="1573435" lims:id="1573435" gazette-part="II" regulation-type="SI" xml:lang="en" xmlns:lims="http://justice.gc.ca/lims"><Identification lims:inforce-start-date="2026-04-17" lims:enacted-date="2026-04-17" lims:fid="1573436" lims:id="1573436"><InstrumentNumber>SI/2026-17</InstrumentNumber><RegistrationDate><Date><YYYY>2026</YYYY><MM>5</MM><DD>6</DD></Date></RegistrationDate><ConsolidationDate><Date><YYYY>2026</YYYY><MM>4</MM><DD>29</DD></Date></ConsolidationDate><EnablingAuthority lims:inforce-start-date="2026-04-17" lims:enacted-date="2026-04-17" lims:fid="1573437" lims:id="1573437"><XRefExternal reference-level="federal" reference-type="act" link="P-34">PUBLIC SERVICE REARRANGEMENT AND TRANSFER OF DUTIES ACT</XRefExternal></EnablingAuthority><LongTitle lims:inforce-start-date="2026-04-17" lims:enacted-date="2026-04-17" lims:fid="1573438" lims:id="1573438">Order Transferring from the Department of Natural Resources to the Department of Employment and Social Development the Control and Supervision of the Sustainable Jobs Secretariat</LongTitle><RegulationMakerOrder><RegulationMaker>P.C.</RegulationMaker><OrderNumber>2026-338</OrderNumber><Date><YYYY>2026</YYYY><MM>4</MM><DD>17</DD></Date></RegulationMakerOrder></Identification><Order lims:inforce-start-date="2026-04-17" lims:enacted-date="2026-04-17" lims:fid="1573439" lims:id="1573439"><Provision lims:inforce-start-date="2026-04-17" lims:enacted-date="2026-04-17" lims:fid="1573440" lims:id="1573440" format-ref="indent-0-0" language-align="yes" list-item="no"><Text>Her Excellency the Governor General in Council, on the recommendation of the Prime Minister, under paragraph 2(a)<FootnoteRef idref="fn_81000-3-3049_hq_1772488392">a</FootnoteRef> of the <XRefExternal reference-type="act" link="P-34">Public Service Rearrangement and Transfer of Duties Act</XRefExternal><FootnoteRef idref="fn_81000-3-3049_hq_1772488410">b</FootnoteRef>, transfers from the Department of Natural Resources to the Department of Employment and Social Development the control and supervision of that portion of the federal public administration in the Department of Natural Resources known as the Sustainable Jobs Secretariat, effective May 1, 2026.</Text><Footnote id="fn_81000-3-3049_hq_1772488392" placement="page" status="official"><Label>a</Label><Text>S.C. 2003, c. 22, s. 207</Text></Footnote><Footnote id="fn_81000-3-3049_hq_1772488410" placement="page" status="official"><Label>b</Label><Text>R.S., c. P-34</Text></Footnote></Provision></Order></Regulation>